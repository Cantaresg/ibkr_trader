# Copy this file to .env and fill in your API keys
# The .env file is gitignored — never commit real keys

# SimFin API key — free tier at https://app.simfin.com/data/api
SIMFIN_KEY=your_simfin_api_key_here

# Finnhub key — free tier at https://finnhub.io (Phase 2+, optional for Phase 1)
FINNHUB_KEY=your_finnhub_key_here
